# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# Kotlin compile daemon scratch (created by Gradle Android builds)
android/.kotlin/

# macOS iCloud sync duplicates — files like "foo 2.txt", "foo 3.txt"
# appear when the same file is edited concurrently across devices.
# These are filesystem artifacts, never to be committed.
* 2.*
* 3.*
* 4.*
* 5.*
* 2
* 3

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Android signing credentials
android/key.properties
*.jks
*.keystore
*.p12

# Machine-specific config
android/local.properties
.vercel
